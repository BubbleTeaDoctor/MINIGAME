  "readyForGeneration": {
    "bestFirstBatch": [
      "board_tiles_basic",
      "board_tile_black_hole",
      "board_tile_spike",
      "unit_placeholders_9_professions",
      "status_icons_core",
      "summon_tokens_visuals",
      "card_frame_set",
      "selection_overlay_set"
